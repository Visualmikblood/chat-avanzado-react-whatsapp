# ==================== CONFIGURACIÓN RÁPIDA ====================
# Copia este archivo como .env y completa tus datos

# ==================== API BACKEND ====================
VITE_API_URL=http://localhost:8000

# ==================== PUSHER ====================
# Usa las MISMAS credenciales que configuraste en api/.env
# Solo necesitas: APP_KEY y CLUSTER
VITE_PUSHER_APP_KEY=      # ← Key de Pusher (MISMO que backend)
VITE_PUSHER_CLUSTER=eu    # ← Cluster (MISMO que backend)
