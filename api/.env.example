# ==================== CONFIGURACIÓN RÁPIDA ====================
# Copia este archivo como .env y completa tus datos

# ==================== DATABASE ====================
DB_HOST=localhost
DB_NAME=chat_app
DB_USER=root
DB_PASS=          # ← TU CONTRASEÑA DE MYSQL

# ==================== JWT ====================
# Genera una clave segura ejecutando: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=       # ← PEGA TU CLAVE GENERADA AQUÍ

# ==================== PUSHER ====================
# Obtén tus credenciales en: https://dashboard.pusher.com/
PUSHER_APP_ID=       # ← App ID de Pusher
PUSHER_APP_KEY=      # ← Key de Pusher
PUSHER_APP_SECRET=   # ← Secret de Pusher
PUSHER_CLUSTER=eu    # ← Cluster (eu, us2, ap1, etc.)

# ==================== CORS ====================
ALLOWED_ORIGINS=http://localhost:5173
